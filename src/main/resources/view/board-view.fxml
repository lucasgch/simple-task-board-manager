<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.desviante.view.BoardViewController">
    <top>
        <!-- Seção <top> com a barra de ferramentas e os botões -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <children>
                <Button fx:id="createBoardButton" onAction="#handleCreateBoard" text="Criar Board" styleClass="btn-primary" />
                <Button fx:id="editBoardButton" onAction="#handleEditBoard" text="Editar Board" styleClass="btn-outline" />
                <Button fx:id="deleteBoardButton" onAction="#handleDeleteBoard" text="Excluir Board" styleClass="btn-outline" />
                <Separator orientation="VERTICAL" />
                <Button fx:id="createGroupButton" onAction="#handleCreateGroup" text="Criar Grupo" styleClass="btn-outline" />
                <Button fx:id="editGroupButton" onAction="#handleEditGroup" text="Editar Grupo" styleClass="btn-outline" />
                <Separator orientation="VERTICAL" />
                <HBox styleClass="filter-chip">
                    <children>
                        <Label text="Grupo" styleClass="label-key" />
                        <ComboBox fx:id="groupFilterComboBox" onAction="#handleGroupFilterChange" promptText="Todos os Grupos" />
                    </children>
                </HBox>
                <HBox styleClass="filter-chip">
                    <children>
                        <Label text="Board" styleClass="label-key" />
                        <ComboBox fx:id="statusFilterComboBox" onAction="#handleStatusFilterChange" promptText="Todos os Status" />
                    </children>
                </HBox>
                <Separator orientation="VERTICAL" />
                <Button fx:id="refreshButton" onAction="#handleRefresh" text="Atualizar" styleClass="btn-ghost" />
                <Button fx:id="syncNowButton" onAction="#handleSyncNow" text="☁ Sincronizar" styleClass="btn-outline" />
                <Label fx:id="syncStatusLabel" styleClass="label-key" />
                <Button fx:id="customTypesButton" onAction="#handleCardTypes" text="Tipos de Card" styleClass="btn-outline" />
                <Button fx:id="preferencesButton" onAction="#handlePreferences" text="Preferências" styleClass="btn-outline" />
                <Button fx:id="googleTaskButton" onAction="#handleGoogleTask" text="Google Task" styleClass="btn-ghost" />
                <Button fx:id="calendarButton" onAction="#handleOpenCalendar" text="📅 Calendário" styleClass="btn-ghost" />
                <Button fx:id="aboutButton" onAction="#handleAbout" text="Sobre" styleClass="btn-ghost" />
            </children>
        </HBox>
    </top>
    <center>
        <!-- Seção <center> -->
        <VBox spacing="10" styleClass="panel" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" />
            </padding>
            <children>
                <Label styleClass="panel-title" text="Meus Boards">
                    <VBox.margin>
                        <Insets left="10" />
                    </VBox.margin>
                </Label>
                <TableView fx:id="boardsTableView" styleClass="boards-table" prefHeight="200.0" minHeight="120.0" VBox.vgrow="NEVER">
                    <columns>
                        <!-- Coluna do ícone do grupo -->
                        <TableColumn fx:id="boardGroupIconColumn" prefWidth="50.0" text="Ícone" />
                        <!-- Coluna do nome do grupo -->
                        <TableColumn fx:id="boardGroupColumn" prefWidth="150.0" text="Grupo" styleClass="group-column" />
                        <!-- Coluna de nome do board -->
                        <TableColumn fx:id="boardNameColumn" prefWidth="250.0" text="Nome" />
                        <!-- COLUNA DE STATUS -->
                        <TableColumn fx:id="boardStatusColumn" prefWidth="120.0" text="Status" />
                        <TableColumn fx:id="statusInitialColumn" prefWidth="120.0" text="Não Iniciado (%)" />
                        <TableColumn fx:id="statusPendingColumn" prefWidth="120.0" text="Em Andamento (%)" />
                        <TableColumn fx:id="statusFinalColumn" prefWidth="120.0" text="Concluído (%)" />
                    </columns>
                </TableView>
                <!-- Separador redimensionável -->
                <Pane fx:id="resizableSeparator" styleClass="resizable-separator" VBox.vgrow="NEVER">
                    <children>
                        <Label text="⋮⋮" styleClass="resize-indicator" />
                    </children>
                </Pane>
                <ScrollPane fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS" prefHeight="300.0" minHeight="200.0">
                    <content>
                        <HBox fx:id="kanbanContainer" spacing="10" fillHeight="true">
                            <padding>
                                <Insets bottom="10" left="10" right="10" top="10" />
                            </padding>
                        </HBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>